    <worksheet name='Profit Ratio by Discount Level per Category'>
      <table>
        <view>
          <datasources>
            <datasource caption='Data Raw (Profitability &amp; Discount Impact Analysis Dashboard_Izzan)' name='federated.1qeaiim10wwfm319leyqy0ni3rv6' />
          </datasources>
          <datasource-dependencies datasource='federated.1qeaiim10wwfm319leyqy0ni3rv6'>
            <column caption='Profit Ratio' datatype='real' default-format='p0.00%' name='[Calculation_0899410885861376]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
            </column>
            <column caption='Discount Level' datatype='string' name='[Calculation_0899410895589377]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.20 THEN &quot;Low Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.40 THEN &quot;Medium Discount&quot;&#13;&#10;ELSE &quot;High Discount&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='real' name='[Discount]' role='measure' type='quantitative' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
