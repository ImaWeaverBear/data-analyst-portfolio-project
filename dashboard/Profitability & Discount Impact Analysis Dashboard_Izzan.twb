      <column caption='Profit Ratio' datatype='real' default-format='p0.00%' name='[Calculation_0899410885861376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Discount Level' datatype='string' name='[Calculation_0899410895589377]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.20 THEN &quot;Low Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.40 THEN &quot;Medium Discount&quot;&#13;&#10;ELSE &quot;High Discount&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Status' datatype='string' name='[Calculation_0899410900348930]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSEIF [Profit] = 0 THEN &quot;No Profit&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Sales Category' datatype='string' name='[Calculation_0899410900606979]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &lt; 100 THEN &quot;Low Sales&quot;&#13;&#10;ELSEIF [Sales] &lt; 500 THEN &quot;Medium Sales&quot;&#13;&#10;ELSE &quot;High Sales&quot;&#13;&#10;END' />
      </column>
