              <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.20 THEN &quot;Low Discount&quot;&#13;&#10;ELSEIF [Discount] &lt;= 0.40 THEN &quot;Medium Discount&quot;&#13;&#10;ELSE &quot;High Discount&quot;&#13;&#10;END' />
